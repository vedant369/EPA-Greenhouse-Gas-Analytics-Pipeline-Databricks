{
  "datasets": [
    {
      "name": "6f6c1125",
      "displayName": "Location Data",
      "queryLines": [
        "select latitude, longitude, `GHG emissions mtons CO2e` as Emissions\n",
        " from emissions.default.emissions_data"
      ]
    },
    {
      "name": "8c982711",
      "displayName": "Emission per person",
      "queryLines": [
        "select\n",
        "  county_state_name,\n",
        "  population,\n",
        "  cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) / population as emissions_per_person\n",
        "from\n",
        "  emissions.default.emissions_data\n",
        "order by\n",
        "  emissions_per_person desc"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "8240fc9a",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "select state_abbr, \n",
        "sum(cast(replace(`GHG emissions mtons CO2e`, ',', '') as double)) as total_emissions\n",
        "from emissions_data\n",
        "group by state_abbr\n",
        "order by total_emissions desc \n",
        "limit 10"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "0e815f42",
      "displayName": "County Shaming",
      "queryLines": [
        "select county_state_name, population, \n",
        "cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) as total_emissions\n",
        "from emissions_data\n",
        "order by total_emissions desc \n",
        "limit 10"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
